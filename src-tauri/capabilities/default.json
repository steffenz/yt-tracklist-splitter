{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the split-set window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "yt-dlp", "sidecar": true },
        { "name": "ffmpeg", "sidecar": true },
        { "name": "ffprobe", "sidecar": true }
      ]
    }
  ]
}
